plugin: amazon.aws.aws_ec2
aws_profile: account1
regions:
  - us-east-1
  - us-west-1
filters:
  instance-state-name: running
hostnames:
  - instance-id
compose:
  ansible_host: instance_id
  ansible_connection: "'aws_ssm'"
  ansible_aws_ssm_region: placement.region
  ansible_aws_ssm_profile: "'account1'"
  ansible_aws_ssm_bucket_name: "'s3-bucket-name'"
